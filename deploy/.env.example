# Core
PUBLIC_URL=http://your-domain-or-ip:8080
JWT_SECRET=replace_with_long_random

# Postgres
POSTGRES_USER=mini
POSTGRES_PASSWORD=mini_password
POSTGRES_DB=mini
DATABASE_URL=postgres://mini:mini_password@db:5432/mini?sslmode=disable

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=media

# LiveKit (must match deploy/livekit.yaml)
LIVEKIT_URL=ws://your-domain-or-ip:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# SMS (mock)
SMS_MOCK_CODE=000000

# Bot auth (stub)
BOT_AUTH_CODE=000000

# TURN/Coturn
COTURN_EXTERNAL_IP=your-public-ip
COTURN_USER=turnuser
COTURN_PASS=turnpass
TURN_REALM=your-domain-or-ip
